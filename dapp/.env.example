# Fluidic dApp environment configuration
# Copy to .env.local for local development or .env.testnet for testnet builds.

# Local mesh_node (default)
VITE_FLUIDIC_API=http://localhost:8080
VITE_FLUIDIC_WS=ws://localhost:8080

# Testnet example
# VITE_FLUIDIC_API=https://api.testnet.fluidic.foundation
# VITE_FLUIDIC_WS=wss://api.testnet.fluidic.foundation
